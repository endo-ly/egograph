# ====================
# Backend API Server
# ====================
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_RELOAD=false
BACKEND_API_KEY=<replace-with-strong-random-api-key>
CORS_ORIGINS=https://<your-tailnet-host>.ts.net
LOG_LEVEL=INFO

# ====================
# LLM Providers
# ====================
DEFAULT_LLM_MODEL=deepseek/deepseek-v3.2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
LLM_ENABLE_WEB_SEARCH=false
OPENAI_API_KEY=<openai-api-key>
ANTHROPIC_API_KEY=<anthropic-api-key>
OPENROUTER_API_KEY=<openrouter-api-key>

# ====================
# Cloudflare R2
# ====================
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=egograph
R2_RAW_PATH=raw/
R2_EVENTS_PATH=events/
R2_MASTER_PATH=master/
LOCAL_PARQUET_ROOT=data/parquet
