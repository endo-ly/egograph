# ====================
# Pipelines Service
# ====================
PIPELINES_DATABASE_PATH=data/pipelines/state.sqlite3
PIPELINES_LOGS_ROOT=data/pipelines/logs
PIPELINES_HOST=127.0.0.1
PIPELINES_PORT=8001
PIPELINES_API_KEY=<replace-with-strong-random-api-key>
PIPELINES_TIMEZONE=UTC
PIPELINES_DISPATCHER_POLL_SECONDS=1.0
PIPELINES_LOCK_LEASE_SECONDS=300
PIPELINES_LOCK_HEARTBEAT_SECONDS=30

# ====================
# Common Source Runtime
# ====================
LOG_LEVEL=INFO
DUCKDB_PATH=data/analytics.duckdb
LOCAL_PARQUET_ROOT=data/parquet

# Cloudflare R2 / S3-compatible object storage
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
R2_BUCKET_NAME=egograph
R2_RAW_PATH=raw/
R2_EVENTS_PATH=events/
R2_MASTER_PATH=master/

# ====================
# Spotify Workflows
# ====================
SPOTIFY_CLIENT_ID=<spotify-client-id>
SPOTIFY_CLIENT_SECRET=<spotify-client-secret>
SPOTIFY_REFRESH_TOKEN=<spotify-refresh-token>
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
SPOTIFY_SCOPE=user-read-recently-played playlist-read-private playlist-read-collaborative

# ====================
# GitHub Workflows
# ====================
GITHUB_PAT=<github-personal-access-token>
GITHUB_LOGIN=<github-login>
# Optional JSON array string, e.g. ["owner/repo1","owner/repo2"]
# GITHUB_TARGET_REPOS=["owner/repo1","owner/repo2"]
GITHUB_BACKFILL_DAYS=365
GITHUB_FETCH_COMMIT_DETAILS=true
GITHUB_MAX_COMMIT_DETAIL_REQUESTS_PER_REPO=200

# ====================
# Google Activity / YouTube Workflows
# ====================
# Optional JSON array string for source common config, e.g. ["account1","account2"]
GOOGLE_ACTIVITY_ACCOUNTS=["account1"]
YOUTUBE_API_KEY=<youtube-data-api-key>
# Cookie JSON string or a local file path readable by the pipelines process.
GOOGLE_COOKIE_ACCOUNT1=./cookies_account1.json
# GOOGLE_COOKIE_ACCOUNT2=./cookies_account2.json

# ====================
# Local Mirror Sync
# ====================
EMBEDDING_MODEL_NAME=cl-nagoya/ruri-v3-310m
EMBEDDING_BATCH_SIZE=32
# Optional. Uncomment only when you want to pin the runtime device.
# EMBEDDING_DEVICE=cuda
EMBEDDING_DIMENSION=768
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=<qdrant-api-key>
QDRANT_COLLECTION_NAME=egograph_spotify_ruri
QDRANT_VECTOR_SIZE=768
QDRANT_BATCH_SIZE=1000
